# Override the API target for the Vite dev-server proxy.
# Default points at the local kind port-forward (matches our Mac dev workflow).
VITE_API_URL=http://127.0.0.1:8080

# Clerk publishable key.  Grab it from the Clerk Dashboard
# (https://dashboard.clerk.com → API Keys) and paste below.
# Without this the app refuses to render -- every route is auth + MFA gated.
VITE_CLERK_PUBLISHABLE_KEY=pk_test_replace-me
